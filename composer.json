{
    "name": "lattice/transport-kafka",
    "description": "Apache Kafka transport adapter for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "kafka",
        "transport",
        "messaging",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/transport-kafka"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Transport\\Kafka\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Transport\\Kafka\\Tests\\": "tests/"
        }
    }
}
